# Copy this file to .env and fill in your values.
# Never commit .env to git — it contains secrets.

# FRED API key — free at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# ── Pricer API mode ─────────────────────────────────────────────────────────
# "local"  → Streamlit calls the engine in-process (default, zero latency)
# "http"   → Streamlit calls the FastAPI backend over HTTP
PRICER_MODE=local
PRICER_API_URL=http://localhost:8000

# ── Binance DCA ────────────────────────────────────────────────────────────────
# Create API key at binance.com → API Management
# Enable ONLY "Spot & Margin Trading" — never enable withdrawals for a bot
# Whitelist your IP address for extra safety
BINANCE_API_KEY=your_binance_api_key_here
# Path to your Ed25519 or RSA private key PEM file (generated locally, never shared)
# Generate with: openssl genpkey -algorithm ed25519 -out ~/.ssh/binance_private.pem
BINANCE_PRIVATE_KEY_PATH=~/.ssh/binance_private.pem

# DCA configuration
DCA_SYMBOL=BTC/EUR          # trading pair (BTC/USDT also works)
DCA_AMOUNT_EUR=100          # EUR to spend per cycle
DCA_DAY_OF_MONTH=1          # day of month to buy (1 = first of month)
DCA_HOUR_LOCAL=20           # local hour to execute (20 = 20:00)
DCA_TIMEZONE=Europe/Paris   # timezone — handles daylight saving automatically
DCA_TESTNET=true            # true = fake money (testnet), false = real money
                            # CHANGE TO false ONLY AFTER TESTING ON TESTNET
